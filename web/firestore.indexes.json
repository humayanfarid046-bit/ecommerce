{
  "_comment": "Only composite indexes belong here. Single-field collection-group indexes are auto-managed; Firebase rejects redundant entries. Admin orderBy fallbacks exist in API routes.",
  "indexes": [
    {
      "collectionGroup": "productReviews",
      "queryScope": "COLLECTION_GROUP",
      "fields": [
        { "fieldPath": "productId", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    }
  ],
  "fieldOverrides": [
    {
      "collectionGroup": "orders",
      "fieldPath": "id",
      "indexes": [
        {
          "order": "ASCENDING",
          "queryScope": "COLLECTION_GROUP"
        }
      ]
    }
  ]
}
