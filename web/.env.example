# Next.js — copy to .env.local (local) or set in Vercel → Project → Settings → Environment Variables.
# Never commit real secrets.
#
# Vercel (this monorepo): Dashboard → New Project → Root Directory = "web" → Import.
# After first deploy, set NEXT_PUBLIC_SITE_URL to your production URL and redeploy.
# If you do not use the separate Express API, leave NEXT_PUBLIC_API_URL empty.

# --- Firebase (client) ---
# Console: Project gear → Project settings → General → Your apps → Web app
# SDK snippet looks like: { apiKey, authDomain, projectId, storageBucket, messagingSenderId, appId }
#
# Firebase JSON key          →  .env variable (same value, copy-paste)
# ----------------              --------------------------
# apiKey                     →  NEXT_PUBLIC_FIREBASE_API_KEY
# authDomain                 →  NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN
# projectId                  →  NEXT_PUBLIC_FIREBASE_PROJECT_ID   ← short id only, e.g. my-shop-123
# storageBucket              →  NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET
# messagingSenderId          →  NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID
# appId                      →  NEXT_PUBLIC_FIREBASE_APP_ID
#
# Do NOT paste Realtime Database URL here — that is NOT projectId.
# If you only use Firestore (this app), ignore Realtime Database URLs in the console.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Public site URL (sitemap, absolute URLs) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Optional: Override legal page URLs shown in footer (Razorpay checklist) ---
# Leave empty to use internal routes: /privacy, /terms, /shipping
NEXT_PUBLIC_PRIVACY_POLICY_URL=
NEXT_PUBLIC_TERMS_POLICY_URL=
NEXT_PUBLIC_REFUND_POLICY_URL=

# --- Optional: Express API (Account → Settings “Backend API”) ---
NEXT_PUBLIC_API_URL=

# --- Razorpay (Checkout: publishable key; secret stays server-only) ---
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Firebase Admin (Next.js API routes: order PATCH, token verify, etc.) ---
# Paste the service account JSON as a single line, or use your host's secret file pattern.
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Misleading demo-only admin UI (fake courier / bulk ship / simulate campaign stats) ---
# Does NOT disable real catalog/CMS. Leave unset in production unless you want those buttons.
NEXT_PUBLIC_ENABLE_DEMO_ADMIN_FEATURES=

# --- Legacy admin cookie API (optional; primary access is Firebase + Firestore accessScope) ---
ADMIN_PASSWORD=
ADMIN_SESSION_TOKEN=
