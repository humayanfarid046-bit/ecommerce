rules_version = '2';

/**
 * AJH Libas Collection — Firestore paths must match `src/lib/firebase/collections.ts`
 * and `src/lib/*-firestore.ts`. Change rules + indexes together; CI can deploy from GitHub
 * (see `.github/workflows/firestore-deploy.yml`).
 *
 * Deploy (from `web/`): `npx firebase deploy --only firestore`
 * Needs `.firebaserc` with project id (copy from `.firebaserc.example`).
 *
 * Server-side Admin (`FIREBASE_SERVICE_ACCOUNT_JSON` on Vercel) bypasses these rules.
 *
 * Optional hardening: move wallet balance updates to Cloud Functions only if you need
 * tamper-proof balances.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    /** Public catalog manifest — written only via Admin SDK (API). */
    match /publicCatalog/manifest {
      allow read: if true;
      allow write: if false;
    }

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    /** Allowed profile document ids under `users/{uid}/profile/{docId}`. */
    function allowedProfileDoc(docId) {
      return docId in [
        'account',
        'addresses',
        'cart',
        'compare',
        'paymentHistory',
        'recentlyViewed',
        'wishlist'
      ];
    }

    match /users/{userId} {

      match /orders/{orderId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      match /profile/{docId} {
        allow read, write: if isOwner(userId) && allowedProfileDoc(docId);
      }

      match /wallet/{docId} {
        allow read, write: if isOwner(userId) && docId == 'snapshot';
      }

      /** Return / refund requests — customer creates; admin updates via Admin SDK. */
      match /returns/{returnId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      /** Product reviews — created via server API (Admin SDK); optional client reads. */
      match /productReviews/{reviewId} {
        allow read: if resource.data.status == 'published' || isOwner(userId);
        allow write: if false;
      }

      /** Order-scoped support chat — owner only (admin uses Admin SDK). */
      match /supportThreads/{threadId} {
        allow read, create, update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }
  }
}
