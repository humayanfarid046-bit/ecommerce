rules_version = '2';

/**
 * AJH Libas Collection â€” Firestore paths must match `src/lib/firebase/collections.ts`
 * and `src/lib/*-firestore.ts`. Change rules + indexes together; CI can deploy from GitHub
 * (see `.github/workflows/firestore-deploy.yml`).
 *
 * Deploy (from `web/`): `npx firebase deploy --only firestore` or `npm run firebase:deploy:firestore`
 * Needs `.firebaserc` with project id (copy from `.firebaserc.example`).
 * CI: repo Secrets `FIREBASE_PROJECT_ID` + `FIREBASE_SERVICE_ACCOUNT_JSON` â†’ push these rules or Actions â†’ Run workflow.
 *
 * Server-side Admin (`FIREBASE_SERVICE_ACCOUNT_JSON` on Vercel) bypasses these rules.
 *
 * Optional hardening: move wallet balance updates to Cloud Functions only if you need
 * tamper-proof balances.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    /** Public catalog manifest â€” written only via Admin SDK (API). */
    match /publicCatalog/manifest {
      allow read: if true;
      allow write: if false;
    }

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    /**
     * Checkout (including COD) writes once via `saveUserOrderToFirestore` â€” same path as other methods.
     * Clients may not update orders after create (prevents faking status/totals); Admin SDK merges updates.
     */
    function userOrderCreateValid(orderId) {
      let d = request.resource.data;
      return d.keys().hasOnly([
        'id', 'placedAt', 'totalRupees', 'methodLabel', 'paymentTxnId',
        'itemCount', 'status', 'shipmentStep', 'itemTitle', 'updatedAt',
        'customerName', 'customerPhone', 'deliveryPin', 'hubCity', 'lineItems',
        'paymentStatus', 'deliveryAddress', 'deliveryLandmark', 'deliveryLat', 'deliveryLng'
      ])
        && d.id == orderId
        && d.id is string && d.id.size() > 0 && d.id.size() <= 120
        && d.placedAt is string && d.placedAt.size() > 0 && d.placedAt.size() <= 80
        && d.totalRupees is number && d.totalRupees >= 0 && d.totalRupees <= 50000000
        && d.methodLabel is string && d.methodLabel.size() > 0 && d.methodLabel.size() <= 500
        && d.paymentTxnId is string && d.paymentTxnId.size() > 0 && d.paymentTxnId.size() <= 200
        && d.itemCount is int && d.itemCount >= 1 && d.itemCount <= 1000
        && d.status == 'placed'
        && d.shipmentStep is int && d.shipmentStep == 0
        && d.itemTitle is string && d.itemTitle.size() <= 2000
        && d.updatedAt is int && d.updatedAt > 0
        && d.customerName is string && d.customerName.size() > 0 && d.customerName.size() <= 200
        && (!d.keys().hasAny(['customerPhone']) || (d.customerPhone is string && d.customerPhone.size() <= 20))
        && (!d.keys().hasAny(['deliveryPin']) || (d.deliveryPin is string && d.deliveryPin.size() <= 10))
        && (!d.keys().hasAny(['lineItems']) || (d.lineItems is list && d.lineItems.size() <= 200))
        && (!d.keys().hasAny(['paymentStatus']) || d.paymentStatus in ['PENDING', 'PAID'])
        && (!d.keys().hasAny(['deliveryAddress']) || (d.deliveryAddress is string && d.deliveryAddress.size() <= 500))
        && (!d.keys().hasAny(['deliveryLandmark']) || (d.deliveryLandmark is string && d.deliveryLandmark.size() <= 200))
        && (!d.keys().hasAny(['deliveryLat']) || (d.deliveryLat is float && d.deliveryLat >= -90.0 && d.deliveryLat <= 90.0))
        && (!d.keys().hasAny(['deliveryLng']) || (d.deliveryLng is float && d.deliveryLng >= -180.0 && d.deliveryLng <= 180.0))
        && (!d.keys().hasAny(['hubCity']) || (d.hubCity is string && d.hubCity.size() <= 120));
    }

    /** Allowed profile document ids under `users/{uid}/profile/{docId}`. */
    function allowedProfileDoc(docId) {
      return docId in [
        'account',
        'addresses',
        'cart',
        'compare',
        'paymentHistory',
        'recentlyViewed',
        'wishlist',
        'delivery'
      ];
    }

    match /users/{userId} {

      match /orders/{orderId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && userOrderCreateValid(orderId);
        allow update: if false;
        allow delete: if isOwner(userId);
      }

      match /profile/{docId} {
        allow read, write: if isOwner(userId) && allowedProfileDoc(docId);
      }

      match /wallet/{docId} {
        allow read, write: if isOwner(userId) && docId == 'snapshot';
      }

      /** Return / refund requests â€” customer creates; admin updates via Admin SDK. */
      match /returns/{returnId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      /** Product reviews â€” created via server API (Admin SDK); optional client reads. */
      match /productReviews/{reviewId} {
        allow read: if resource.data.status == 'published' || isOwner(userId);
        allow write: if false;
      }

      /** Order-scoped support chat â€” owner only (admin uses Admin SDK). */
      match /supportThreads/{threadId} {
        allow read, create, update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    /** Inventory is server-managed via Admin SDK + API only. */
    match /inventoryVariants/{docId} {
      allow read, write: if false;
    }
    match /inventoryMovements/{docId} {
      allow read, write: if false;
    }
    match /inventoryReservations/{docId} {
      allow read, write: if false;
    }
    match /purchaseOrders/{docId} {
      allow read, write: if false;
    }
    match /goodsReceipts/{docId} {
      allow read, write: if false;
    }
    match /stockTransfers/{docId} {
      allow read, write: if false;
    }
    match /inventoryAlerts/{docId} {
      allow read, write: if false;
    }

    /** Rider COD wallet aggregates â€” Admin SDK only. */
    match /riderWallets/{uid} {
      allow read, write: if false;
    }
    match /riderWallets/{uid}/settlements/{sid} {
      allow read, write: if false;
    }
  }
}
