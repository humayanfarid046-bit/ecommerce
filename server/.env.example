# Express API — copy to .env next to server/package.json
PORT=4000

# Comma-separated origins for browser requests (Next.js dev server included by default in code)
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Firebase Admin — pick ONE approach:

# A) Individual env vars (escape newlines in private key as \n)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# B) Path to service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\serviceAccount.json
